    let currentLang = localStorage.getItem('wlc-lang') || (navigator.language.startsWith('tr') ? 'tr' : 'en');

    function updateContent() {
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (translations[currentLang][key]) {
          el.innerHTML = translations[currentLang][key];
        }
      });

      // Update active button state
      document.getElementById('btn-en').classList.toggle('bg-wj-blue', currentLang === 'en');
      document.getElementById('btn-en').classList.toggle('text-white', currentLang === 'en');
      document.getElementById('btn-tr').classList.toggle('bg-wj-blue', currentLang === 'tr');
      document.getElementById('btn-tr').classList.toggle('text-white', currentLang === 'tr');
      
      document.documentElement.lang = currentLang;
    }

    document.getElementById('btn-en').addEventListener('click', () => {
      currentLang = 'en';
      localStorage.setItem('wlc-lang', currentLang);
      updateContent();
    });

    document.getElementById('btn-tr').addEventListener('click', () => {
      currentLang = 'tr';
      localStorage.setItem('wlc-lang', currentLang);
      updateContent();
    });

    // Initial load
    updateContent();
  </script>
